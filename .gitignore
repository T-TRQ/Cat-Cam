# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Editors / IDEs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Secrets
# Never commit anything matching these. Use *.example files as templates,
# e.g. commit `.env.example` (no real values) but never `.env`.
# =============================================================================
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
secrets/
credentials/

# =============================================================================
# Python (pi/, server/)
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# =============================================================================
# Node (web/)
# =============================================================================
node_modules/
.next/
out/
.turbo/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml

# =============================================================================
# Media / data — never commit clips, snapshots, or DB dumps
# (allow images in docs/ for diagrams etc.)
# =============================================================================
*.mp4
*.mkv
*.avi
*.mov
*.jpg
*.jpeg
*.png
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.jpeg
*.db
*.sqlite
*.sqlite3
data/
clips/
snapshots/

# =============================================================================
# Misc
# =============================================================================
*.log
*.tmp
